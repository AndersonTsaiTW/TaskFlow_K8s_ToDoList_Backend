# Application Settings
ENV=development
DEBUG=true
API_TITLE=TaskFlow API
API_VERSION=1.0.0

# Server Configuration
HOST=0.0.0.0
PORT=8000

# CORS Settings (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Database Configuration (when implemented)
# Local dev (venv): Use localhost
# DATABASE_URL=postgresql://taskflow:password@localhost:5432/taskflow
# Docker dev: docker-compose.yml overrides to db:5432
# DATABASE_URL=sqlite:///./taskflow.db

# Security (generate your own secret key)
# SECRET_KEY=your-secret-key-here
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30

# Logging
LOG_LEVEL=INFO
SQL_ECHO=false

# Test Configuration
TEST_DATABASE_URL=sqlite:///./test_taskflow.db
HURL_BASE_URL=http://localhost:8000

# ========================================
# AWS CI/CD (placeholders, do not commit real secrets)
# ========================================
AWS_ACCOUNT_ID=YOUR_AWS_ACCOUNT_ID
AWS_REGION=ca-central-1
AWS_ROLE_NAME=github-actions-ecr-push-role
AWS_ROLE_ARN=arn:aws:iam::YOUR_AWS_ACCOUNT_ID:role/github-actions-ecr-push-role
ECR_API_REPOSITORY=taskflow/api
ECR_WEB_REPOSITORY=taskflow/web
